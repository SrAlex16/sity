{
  "name": "sity-panel",
  "version": "1.0.0",
  "description": "Sity system monitor panel for Raspberry Pi",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron dist-electron/main.js",
    "package": "npm run build && electron-builder --linux dir"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "systeminformation": "^5.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.sity.panel",
    "productName": "Sity Monitor",
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": "dir",
      "category": "System"
    }
  }
}
